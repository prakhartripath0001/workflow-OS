# Workflow OS local Docker settings
#
# These names are project-specific on purpose. Generic names like POSTGRES_USER
# are often already set in developer shells and can accidentally break Compose.

WORKFLOWOS_POSTGRES_DB=workflowos
WORKFLOWOS_POSTGRES_USER=workflowos
WORKFLOWOS_POSTGRES_PASSWORD=workflowos

POSTGRES_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=3000

SPRING_PROFILE=dev
OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:5173

# Optional OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
