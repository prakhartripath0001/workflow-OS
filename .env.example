# =============================================================================
#  Workflow OS — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=workflowos
POSTGRES_USER=workflowos
POSTGRES_PASSWORD=workflowos_secret_change_me
POSTGRES_PORT=5432

# ─── Backend ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
SPRING_PROFILE=prod

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
