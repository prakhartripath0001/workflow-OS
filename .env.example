# =============================================================================
#  SlashAI — Environment Variables Reference
#  Copy this file to .env and fill in your real values.
#  NEVER commit the actual .env file — it is in .gitignore.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=slashai
POSTGRES_USER=slashai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# ─── Spring Boot ─────────────────────────────────────────────────────────────
BACKEND_PORT=8080
SPRING_PROFILE=dev               # dev | prod

# ─── Frontend (Docker) ───────────────────────────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# MUST be at least 256 bits (32 bytes) for HS256 algorithm
JWT_SECRET=REPLACE_WITH_SECURE_SECRET_openssl_rand_base64_64
JWT_EXPIRY_MS=900000             # 15 minutes (access token)
JWT_REFRESH_EXPIRY_MS=604800000 # 7 days (refresh token)

# ─── Google OAuth2 ───────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── GitHub OAuth2 ───────────────────────────────────────────────────────────
# Get from: https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: http://localhost:8080/login/oauth2/code/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── OAuth2 Redirect (after successful login) ─────────────────────────────────
OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:5173

# ─── AI Service (future) ──────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Gmail Integration ────────────────────────────────────────────────────────
# GMAIL_SERVICE_ACCOUNT_KEY_PATH=/secrets/gmail-sa.json

# ─── Monitoring (future) ──────────────────────────────────────────────────────
# SENTRY_DSN=https://...
# DATADOG_API_KEY=...

# ─── Deployment ───────────────────────────────────────────────────────────────
# DEPLOY_HOST=your.server.ip
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
